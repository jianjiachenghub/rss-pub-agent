# === LLM 提供商 ===
# 优先级链，逗号分隔。只有配了 API Key 的才会生效
# 可选值: openrouter, gemini, openai, zhipu, deepseek, siliconflow
LLM_PROVIDERS=openrouter,gemini,openai

# OpenRouter (https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# 可选：覆盖 OpenRouter 的 flash / pro 模型，无需改代码
# OPENROUTER_FLASH_MODEL=openai/gpt-4o-mini
# OPENROUTER_PRO_MODEL=openai/gpt-4o

# 智谱 GLM (https://open.bigmodel.cn/)
# ZHIPU_API_KEY=your_zhipu_api_key_here

# Google Gemini (https://ai.google.dev/)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_FLASH_MODEL=gemini-2.0-flash
# GEMINI_PRO_MODEL=gemini-2.5-pro

# OpenAI (https://platform.openai.com/)
# OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek (https://platform.deepseek.com/)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# SiliconFlow (https://siliconflow.cn/)
# SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# === 可选 - 数据源 ===
# Folo API Session Token (用于 Folo 数据源抓取)
# FOLO_SESSION_TOKEN=your_folo_session_token_here

# === 可选 - Telegram 通知 ===
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === 可选 - 微信通知 ===
# WECHAT_WEBHOOK_URL=your_wechat_webhook_url_here

# === 可选 - Cloudflare R2 (播客音频存储) ===
# R2_ACCESS_KEY=your_r2_access_key_here
# R2_SECRET_KEY=your_r2_secret_key_here
# R2_ACCOUNT_ID=your_r2_account_id_here
# R2_BUCKET=llm-news-flow
# R2_PUBLIC_DOMAIN=your_r2_public_domain_here
