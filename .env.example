# === 必需 ===
# Gemini API Key (主力 LLM 提供商)
GEMINI_API_KEY=your_gemini_api_key_here

# === 可选 - LLM 备用 ===
# OpenAI API Key (Gemini 不可用时的 fallback)
OPENAI_API_KEY=your_openai_api_key_here

# === 可选 - 数据源 ===
# Folo API Session Token (用于 Folo 数据源抓取)
FOLO_SESSION_TOKEN=your_folo_session_token_here

# === 可选 - Telegram 通知 ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === 可选 - 微信通知 ===
WECHAT_WEBHOOK_URL=your_wechat_webhook_url_here

# === 可选 - Cloudflare R2 (播客音频存储) ===
R2_ACCESS_KEY=your_r2_access_key_here
R2_SECRET_KEY=your_r2_secret_key_here
R2_ACCOUNT_ID=your_r2_account_id_here
R2_BUCKET=llm-news-flow
R2_PUBLIC_DOMAIN=your_r2_public_domain_here
